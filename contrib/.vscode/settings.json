{
  // This disables vscode from adding lines to files.associations,
  // some files might not be recognized though.
  // This is a vscode issue.
  "C_Cpp.autoAddFileAssociations": false,
  "files.associations": {
    "*.c": "c",
    "*.h": "cpp",
    "*.cpp": "cpp",
    "*.hpp": "cpp",
    "*.cxx": "cpp",
    "*.hxx": "cpp",
    "*.py": "python",
    "*.FCMacro": "python"
  },
  // This is needed to make the python language server work with the FreeCAD source code, 
  // otherwise it will not be able to find the modules and will show errors for all the imports.
  // Hardcoding the paths is not ideal, but it felt like the best tradeoff to avoid having to
  // build a system to generate this dynamically.
  "python.analysis.extraPaths": [
  "${workspaceFolder}/pyside_compatibility",
  "${workspaceFolder}/src/Mod/AddonManager",
  "${workspaceFolder}/src/Mod/Assembly",
  "${workspaceFolder}/src/Mod/BIM",
  "${workspaceFolder}/src/Mod/CAM",
  "${workspaceFolder}/src/Mod/Cloud",
  "${workspaceFolder}/src/Mod/Draft",
  "${workspaceFolder}/src/Mod/Fem",
  "${workspaceFolder}/src/Mod/Help",
  "${workspaceFolder}/src/Mod/Import",
  "${workspaceFolder}/src/Mod/Inspection",
  "${workspaceFolder}/src/Mod/JtReader",
  "${workspaceFolder}/src/Mod/Material",
  "${workspaceFolder}/src/Mod/Measure",
  "${workspaceFolder}/src/Mod/Mesh",
  "${workspaceFolder}/src/Mod/MeshPart",
  "${workspaceFolder}/src/Mod/OpenSCAD",
  "${workspaceFolder}/src/Mod/Part",
  "${workspaceFolder}/src/Mod/PartDesign",
  "${workspaceFolder}/src/Mod/Plot",
  "${workspaceFolder}/src/Mod/Points",
  "${workspaceFolder}/src/Mod/ReverseEngineering",
  "${workspaceFolder}/src/Mod/Robot",
  "${workspaceFolder}/src/Mod/Sandbox",
  "${workspaceFolder}/src/Mod/Show",
  "${workspaceFolder}/src/Mod/Sketcher",
  "${workspaceFolder}/src/Mod/Spreadsheet",
  "${workspaceFolder}/src/Mod/Start",
  "${workspaceFolder}/src/Mod/Surface",
  "${workspaceFolder}/src/Mod/TechDraw",
  "${workspaceFolder}/src/Mod/TemplatePyMod",
  "${workspaceFolder}/src/Mod/Test",
  "${workspaceFolder}/src/Mod/Tux",
  "${workspaceFolder}/src/Mod/Web",
  "${workspaceFolder}/src/Mod",
  ],
  "editor.formatOnType": true,
  "files.autoSave": "afterDelay",
  "debug.onTaskErrors": "abort", //to not launch the python debugger when waitforport.py fails

  // Does not quick launch the debugger, forces to select debugger config every time
  // Use the debug panel on the left instead
  "debug.showInStatusBar": "never",

  "cmake.options.advanced": {
    "configurePreset": {
      "statusBarVisibility": "visible"
    },
    "build": {
      "statusBarVisibility": "visible"
    },
    "launch": {
      "statusBarVisibility": "hidden"
    },
    "debug": {
      "statusBarVisibility": "hidden"
    }
  },

  // CMake Tools: use the conda-windows-debug preset which sets FREECAD_LIBPACK_USE=OFF, BUILD_WITH_CONDA=ON, etc.
  "cmake.configurePreset": "conda-windows-debug",
  "cmake.cmakePath": "${workspaceFolder}/.pixi/envs/default/Library/bin/cmake.exe",
  "cmake.buildDirectory": "${workspaceFolder}/build/debug",
  "cmake.configureSettings": {
    "CMAKE_BUILD_TYPE": "Debug",
    "CMAKE_PREFIX_PATH": "${workspaceFolder}/.pixi/envs/default/Library",
    "FREECAD_RELEASE_PDB": "OFF"
  },

  // Set Pixi environment variables for CMake Tools so moc.exe and other tools find their DLLs
  "cmake.environment": {
    "PATH": "${workspaceFolder}/.pixi/envs/default;${workspaceFolder}/.pixi/envs/default/Library/mingw-w64/bin;${workspaceFolder}/.pixi/envs/default/Library/usr/bin;${workspaceFolder}/.pixi/envs/default/Library/bin;${workspaceFolder}/.pixi/envs/default/Library/lib/qt6;${workspaceFolder}/.pixi/envs/default/Scripts;${workspaceFolder}/.pixi/envs/default/bin;${env:PATH}",
    "CONDA_PREFIX": "${workspaceFolder}/.pixi/envs/default"
  }
}